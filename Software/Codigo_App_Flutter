enum ControlMode {
  manual,
  automatic,
  stopped,
}

class RobotControlScreen extends StatefulWidget {
  const RobotControlScreen({super.key});

  @override
  State<RobotControlScreen> createState() => _RobotControlScreenState();
}

class _RobotControlScreenState extends State<RobotControlScreen> {
  final TextEditingController ipController =
      TextEditingController(text: '192.168.0.20');

  WebSocketChannel? channel;
  bool connected = false;
  String connectionText = 'Desconectado';

  int selectedTab = 0;

  ControlMode selectedMode = ControlMode.manual;

  double maxLinear = 0.30;
  double maxAngular = 0.85;

  double currentLinear = 0.0;
  double currentAngular = 0.0;

  Timer? commandTimer;

  String robotModeText = 'MANUAL';

  bool bumperDer = false;
  bool bumperFront = false;
  bool bumperIzq = false;
  bool bumperTras = false;

  bool cuttersOn = false;

  double dIzq = -1;
  double dFront = -1;
  double dDer = -1;

  int autoElapsed = 0;

  final MapController mapController = MapController();

  LatLng robotPosition = const LatLng(-25.3390, -57.5190);
  bool gpsReceived = false;

  final List<LatLng> robotPath = [];
  final List<LatLng> geofencePoints = [];

  void connectToRobot() {
    final ip = ipController.text.trim();
    final url = 'ws://$ip:9090';

    channel?.sink.close();

    try {
      channel = WebSocketChannel.connect(Uri.parse(url));

      setState(() {
        connected = true;
        connectionText = 'Conectado a $url';
      });

      listenToRosMessages();
      subscribeToRobotStatus();
      subscribeToGps();

      debugPrint('Conectado a $url');
    } catch (e) {
      setState(() {
        connected = false;
        connectionText = 'Error de conexión';
      });

      debugPrint('Error: $e');
    }
  }

  void disconnectRobot() {
    emergencyStop(sendStopMode: true);
    channel?.sink.close();

    setState(() {
      connected = false;
      connectionText = 'Desconectado';
    });
  }

  void listenToRosMessages() {
    channel!.stream.listen(
      (event) {
        final data = jsonDecode(event);

        if (data['topic'] == '/robot/status') {
          final msg = data['msg'];
          if (msg == null || msg['data'] == null) return;

          final statusData = jsonDecode(msg['data']);

          setState(() {
            robotModeText = statusData['mode'] ?? robotModeText;

            bumperDer = statusData['bumper_der'] == 1;
            bumperFront = statusData['bumper_front'] == 1;
            bumperIzq = statusData['bumper_izq'] == 1;
            bumperTras = statusData['bumper_tras'] == 1;

            cuttersOn = statusData['cutters_on'] == 1;

            dIzq = (statusData['d_izq'] ?? -1).toDouble();
            dFront = (statusData['d_front'] ?? -1).toDouble();
            dDer = (statusData['d_der'] ?? -1).toDouble();

            autoElapsed = statusData['auto_elapsed'] ?? 0;
          });
        }

        if (data['topic'] == '/robot/gps') {
          final msg = data['msg'];
          if (msg == null) return;

          final lat = msg['latitude'];
          final lon = msg['longitude'];

          if (lat == null || lon == null) return;

          final newPosition = LatLng(
            lat.toDouble(),
            lon.toDouble(),
          );

          setState(() {
            robotPosition = newPosition;
            gpsReceived = true;

            if (robotPath.isEmpty || robotPath.last != newPosition) {
              robotPath.add(newPosition);
            }
          });
        }
      },
      onError: (_) {
        setState(() {
          connected = false;
          connectionText = 'Error WebSocket';
        });
      },
      onDone: () {
        setState(() {
          connected = false;
          connectionText = 'Conexión cerrada';
        });
      },
    );
  }

  void sendRosMessage(Map<String, dynamic> message) {
    if (!connected || channel == null) {
      debugPrint('No conectado');
      return;
    }

    final jsonMessage = jsonEncode(message);
    channel!.sink.add(jsonMessage);
    debugPrint('Enviado: $jsonMessage');
  }

  void subscribeToRobotStatus() {
    sendRosMessage({
      "op": "subscribe",
      "topic": "/robot/status",
      "type": "std_msgs/String",
    });
  }

  void subscribeToGps() {
    sendRosMessage({
      "op": "subscribe",
      "topic": "/robot/gps",
      "type": "sensor_msgs/NavSatFix",
    });
  }

  void publishString(String topic, String value) {
    sendRosMessage({
      "op": "publish",
      "topic": topic,
      "msg": {"data": value},
    });
  }

  void publishCmdVel(double linear, double angular) {
    sendRosMessage({
      "op": "publish",
      "topic": "/cmd_vel",
      "msg": {
        "linear": {
          "x": linear,
          "y": 0.0,
          "z": 0.0,
        },
        "angular": {
          "x": 0.0,
          "y": 0.0,
          "z": angular,
        }
      }
    });
  }

  void setMode(ControlMode mode) {
    setState(() {
      selectedMode = mode;
    });

    if (mode == ControlMode.manual) {
      stopSendingCommands();
      publishString('/app/mode_cmd', 'MANUAL');
    } else if (mode == ControlMode.automatic) {
      stopSendingCommands();
      publishString('/app/mode_cmd', 'AUTO');
    } else {
      emergencyStop(sendStopMode: true);
    }
  }

  void toggleCutters() {
    if (cuttersOn) {
      publishString('/app/cutters_cmd', 'OFF');
    } else {
      publishString('/app/cutters_cmd', 'ON');
    }
  }

  void startSendingCommands() {
    if (selectedMode != ControlMode.manual) return;

    commandTimer ??= Timer.periodic(
      const Duration(milliseconds: 100),
      (_) {
        publishCmdVel(currentLinear, currentAngular);
      },
    );
  }

  void stopSendingCommands() {
    commandTimer?.cancel();
    commandTimer = null;

    currentLinear = 0.0;
    currentAngular = 0.0;

    publishCmdVel(0.0, 0.0);

    setState(() {});
  }

  void onJoystickChanged(double x, double y) {
    if (selectedMode != ControlMode.manual) return;

    currentLinear = (-y * maxLinear).clamp(-maxLinear, maxLinear);
    currentAngular = (-x * maxAngular).clamp(-maxAngular, maxAngular);

    if (connected) {
      startSendingCommands();
    }

    setState(() {});
  }

  void emergencyStop({bool sendStopMode = false}) {
    stopSendingCommands();
    publishString('/app/cutters_cmd', 'OFF');
    publishString('/app/autonomous_cmd', 'STOP');

    if (sendStopMode) {
      publishString('/app/mode_cmd', 'STOPPED');
    }

    setState(() {
      selectedMode = ControlMode.stopped;
    });
  }

  void addGeofencePoint(LatLng point) {
    setState(() {
      geofencePoints.add(point);
    });
  }

  void clearGeofence() {
    setState(() {
      geofencePoints.clear();
    });
  }

  void undoLastGeofencePoint() {
    if (geofencePoints.isEmpty) return;

    setState(() {
      geofencePoints.removeLast();
    });
  }

  void sendGeofenceToRos() {
    if (geofencePoints.length < 4) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text('El cerco virtual necesita al menos 4 puntos.'),
        ),
      );
      return;
    }

    final points = geofencePoints.map((p) {
      return {
        "lat": p.latitude,
        "lon": p.longitude,
      };
    }).toList();

    final payload = jsonEncode({
      "points": points,
    });

    publishString('/app/geofence', payload);

    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(
        content: Text('Cerco virtual enviado a ROS2.'),
      ),
    );
  }

  void centerMapOnRobot() {
    mapController.move(robotPosition, 18);
  }

  void clearPath() {
    setState(() {
      robotPath.clear();
    });
  }

  @override
  void dispose() {
    commandTimer?.cancel();
    channel?.sink.close();
    ipController.dispose();
    super.dispose();
  }

