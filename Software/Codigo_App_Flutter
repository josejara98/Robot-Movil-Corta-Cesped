          ),
        ],
      ),
    );
  }
}

class VirtualJoystick extends StatefulWidget {
  final bool enabled;
  final void Function(double x, double y) onChanged;
  final VoidCallback onReleased;

  const VirtualJoystick({
    super.key,
    required this.enabled,
    required this.onChanged,
    required this.onReleased,
  });

  @override
  State<VirtualJoystick> createState() => _VirtualJoystickState();
}

class _VirtualJoystickState extends State<VirtualJoystick> {
  Offset knobOffset = Offset.zero;

  static const double size = 210;
  static const double knobSize = 78;
  static const double radius = size / 2;
  static const double maxDistance = radius - knobSize / 2;

  void updateJoystick(Offset localPosition) {
    if (!widget.enabled) return;

    final center = const Offset(radius, radius);
    Offset delta = localPosition - center;

    if (delta.distance > maxDistance) {
      delta = Offset.fromDirection(delta.direction, maxDistance);
    }

    final normalizedX = delta.dx / maxDistance;
    final normalizedY = delta.dy / maxDistance;

    setState(() {
      knobOffset = delta;
    });

    widget.onChanged(normalizedX, normalizedY);
  }

  void releaseJoystick() {
    setState(() {
      knobOffset = Offset.zero;
    });

    widget.onReleased();
  }

  @override
  Widget build(BuildContext context) {
    final baseColor =
        widget.enabled ? Colors.green.shade100 : Colors.grey.shade200;
    final borderColor =
        widget.enabled ? Colors.green.shade700 : Colors.grey.shade400;
    final knobColor = widget.enabled ? Colors.green.shade800 : Colors.grey;

    return Listener(
      onPointerDown: (event) {
        final box = context.findRenderObject() as RenderBox;
        final local = box.globalToLocal(event.position);
        updateJoystick(local);
      },
      onPointerMove: (event) {
        final box = context.findRenderObject() as RenderBox;
        final local = box.globalToLocal(event.position);
        updateJoystick(local);
      },
      onPointerUp: (_) => releaseJoystick(),
      onPointerCancel: (_) => releaseJoystick(),
      child: SizedBox(
        width: size,
        height: size,
        child: Stack(
          alignment: Alignment.center,
          children: [
            Container(
              width: size,
              height: size,
              decoration: BoxDecoration(
                shape: BoxShape.circle,
                color: baseColor,
                border: Border.all(
                  color: borderColor,
                  width: 3,
                ),
              ),
              child: const Center(
                child: Icon(
                  Icons.control_camera,
                  size: 44,
                  color: Colors.black38,
                ),
              ),
            ),
            Transform.translate(
              offset: knobOffset,
              child: Container(
                width: knobSize,
                height: knobSize,
                decoration: BoxDecoration(
                  shape: BoxShape.circle,
                  color: knobColor,
                  boxShadow: const [
                    BoxShadow(
                      blurRadius: 10,
                      spreadRadius: 1,
                      offset: Offset(0, 4),
                      color: Colors.black26,
                    ),
                  ],
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }
}
