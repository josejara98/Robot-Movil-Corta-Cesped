  Widget mapTab() {
    return Column(
      children: [
        Container(
          padding: const EdgeInsets.all(10),
          color: Colors.white,
          child: Row(
            children: [
              Icon(
                gpsReceived ? Icons.gps_fixed : Icons.gps_off,
                color: gpsReceived ? Colors.green : Colors.red,
              ),
              const SizedBox(width: 8),
              Expanded(
                child: Text(
                  gpsReceived
                      ? 'GPS: ${robotPosition.latitude.toStringAsFixed(6)}, ${robotPosition.longitude.toStringAsFixed(6)}'
